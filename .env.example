# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# RSS Feed URLs (comma separated)
RSS_FEEDS=https://hnrss.org/frontpage,https://export.arxiv.org/rss/cs.AI,https://export.arxiv.org/rss/cs.LG,https://export.arxiv.org/rss/cs.CL

# Keywords to filter (comma separated)
KEYWORDS=AI,machine learning,deep learning,LLM,NLP,computer vision,AGI,GPT,diffusion,transformers,multimodal

# Daily collection limit
DAILY_LIMIT=20

# Max entries to process per feed (reduce for arXiv feeds)
MAX_ENTRIES_PER_FEED=30

# Collection time (UTC)
COLLECTION_TIME=00:00